<button
  type="button"
  title="Toggle Analysis Table Columns Visibility"
  class="btn btn-default"
  {{on "click" (toggle "isModalVisible" this)}}
  ...attributes
>
  <FaIcon @icon="gear" @prefix="fas" @size="sm" />
</button>
{{#if this.isModalVisible}}
  <Modal
    @visible={{this.isModalVisible}}
    @onClose={{toggle "isModalVisible" this}}
    class="md:w-auto"
    as |modal|
  >
    <div class="sm:min-w-[32rem]">
      <modal.header>
        <h3>Hide / Show Table Columns</h3>
      </modal.header>
      <modal.body class="grid gap-2">
        {{#each this.columns as |column|}}
          <Checkbox
            @checked={{column.isVisible}}
            @onChange={{fn this.toggleColumn column}}
          >
            {{column.label}}
          </Checkbox>
        {{/each}}
      </modal.body>
      <modal.footer class="flex justify-end">
        <button class="btn btn-primary" {{on "click" this.save}} type="button">
          Save
        </button>
      </modal.footer>
    </div>
  </Modal>
{{/if}}