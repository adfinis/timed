<textarea
  type="text"
  class="comment-field resize-none overflow-hidden rounded transition-[height] duration-300 ease-in-out
    {{if @customerVisible 'customer-comment'}}
    {{this.heightClass}}"
  placeholder="Comment"
  name="comment"
  id="row-comment"
  value={{@value}}
  disabled={{@disabled}}
  title={{this.tooltip}}
  spellcheck="true"
  autocomplete="true"
  wrap="soft"
  rows="1"
  {{on "input" (pick "target.value" @onChange)}}
  {{on "keydown" this.handleKeydown}}
  data-test-report-comment
/>