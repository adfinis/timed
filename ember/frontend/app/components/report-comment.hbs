<textarea
  type="text"
  class="form-textarea comment-field rounded
    {{if @customerVisible 'customer-comment'}}
    {{if @value 'line-clamp'}}
    {{this.heightClass}}"
  placeholder="Comment"
  name="comment"
  id="row-comment"
  value={{@value}}
  disabled={{@disabled}}
  title={{this.tooltip}}
  spellcheck="true"
  autocomplete="true"
  {{on "input" (pick "target.value" @onUpdate)}}
  data-test-report-comment
/>