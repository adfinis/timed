{
  "name": "timed",
  "version": "0.0.0",
  "private": true,
  "description": "A time tracking software written in Ember.js",
  "repository": "https://github.com/adfinis/timed",
  "license": "AGPL-3.0",
  "author": "Adfinis AG <info@adfinis.com>",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "prebuild": "pnpm --filter ui-core build",
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint --fix \"**/*.css\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "start": "vite",
    "pretest": "pnpm --filter ui-core build",
    "test": "ember test",
    "test:ember": "vite build --mode development && ember test --path dist"
  },
  "dependencies": {
    "@glimmer/component": "2.1.1"
  },
