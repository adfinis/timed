{
  "extends": "@ember/app-tsconfig",
  "include": [
    "src/**/*",
    "tests/**/*",
    "unpublished-development-types/**/*",
    "demo-app/**/*"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "ember-source": ["node_modules/ember-source"],
      "ember-source/*": ["node_modules/ember-source/*"],
      "@glimmer/component": ["node_modules/@glimmer/component"],
      "@glimmer/component/*": ["node_modules/@glimmer/component/*"]
    },
    "types": [
      "ember-source/types",
      "vite/client",
      "@embroider/core/virtual",
      "@glint/ember-tsc/types"
    ]
  }
}
